{
  "name": "elecjs",
  "version": "1.0.0",
  "description": "Secure Electron + React + TypeScript + SQLite app",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "rebuild:native": "electron-builder install-app-deps",
    "lint": "eslint .",
    "dist": "npm run build && electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "better-sqlite3": "^12.6.2",
    "chart.js": "^4.5.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.3",
    "eslint-plugin-react-hooks": "^6.1.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1"
  },
  "build": {
    "appId": "com.local.suite",
    "productName": "YerelSuit",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**",
      "node_modules/**",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [
      "**/*.node"
    ],
    "win": {
      "target": ["portable"],
      "signAndEditExecutable": false,
      "artifactName": "${productName}-${version}.${ext}",
      "icon": "iconfinder-technologymachineelectronicdevice23-4026437_113360.png"
    },
    "mac": {
      "target": ["dmg"],
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": ["AppImage"],
      "category": "Office"
    },
    "extraResources": [
      "iconfinder-technologymachineelectronicdevice23-4026437_113360.png"
    ]
  }
}
